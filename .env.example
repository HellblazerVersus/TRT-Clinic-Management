# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://trt_user:trt_secret@localhost:5432/trt_clinic

# ─── NextAuth ────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-in-production

# ─── Twilio SMS ──────────────────────────────────────────────────────────────
# Set TWILIO_MOCK=true to log SMS to console instead of sending
TWILIO_MOCK=true
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+15005550006

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Cron Security ───────────────────────────────────────────────────────────
# Include as header: x-cron-secret: <value>
CRON_SECRET=change-me-in-production
